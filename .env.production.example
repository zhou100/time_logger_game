# ── Backend (set these in Render dashboard — never commit real values) ────────

# Supabase — session-mode pooler (port 5432 = works with asyncpg)
DATABASE_URL=postgresql+asyncpg://postgres.[project-ref]:[password]@aws-0-us-east-1.pooler.supabase.com:5432/postgres

# Generate with: openssl rand -hex 32
SECRET_KEY=change-me

# OpenAI
OPENAI_API_KEY=sk-...

# Cloudflare R2
S3_ENDPOINT_URL=https://<ACCOUNT_ID>.r2.cloudflarestorage.com
S3_ACCESS_KEY=<R2_ACCESS_KEY_ID>
S3_SECRET_KEY=<R2_SECRET_ACCESS_KEY>
S3_BUCKET=time-logger-audio
S3_REGION=auto

# CORS — comma-separated list of allowed frontend origins
ALLOWED_ORIGINS=https://time-logger.pages.dev,https://yourdomain.com

# App
ENVIRONMENT=production
LOG_LEVEL=INFO
ACCESS_TOKEN_EXPIRE_MINUTES=15
REFRESH_TOKEN_EXPIRE_DAYS=30
DB_ECHO=false

# ── Frontend (set in Cloudflare Pages dashboard) ──────────────────────────────

REACT_APP_API_URL=https://time-logger-backend.onrender.com
